{
  "functions": {
    "src/app/api/submit/route.ts": { "memory": 1024, "maxDuration": 60 },
    "src/app/[locale]/f/[slug]/page.tsx": { "memory": 1024, "maxDuration": 60 },
    "src/app/[locale]/admin/(authenticated)/forms/[id]/page.tsx": { "memory": 1024, "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/f/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
